# ====================================
# LLM
# ====================================

LLM_PROVIDER=gemini

LLM_MODEL=gemini-3.1-flash-lite

VISION_LLM_MODEL=gemini-3.1-flash-lite

DOCX_LLM_MODEL=gemini-3.1-flash-lite

MAX_DOC_PAGES=6

# ====================================
# GOOGLE CLOUD
# ====================================

PROJECT_ID=your-gcp-project-id

GCP_LOCATION=global

# ====================================
# FIREBASE
# ====================================

FIREBASE_PROJECT_ID=your-project-id

FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

FIREBASE_CREDENTIALS_PATH=/path/to/service-account.json

ALLOW_FIREBASE_MOCKS=false

# Set to true in local development to bypass Firebase Admin SDK auth verification
# and use a mock Firestore backend. NEVER set to true in production.
# ALLOW_FIREBASE_MOCKS=true

# ====================================
# API KEYS
# ====================================

GEMINI_API_KEY=

OPENAI_API_KEY=

GROQ_API_KEY=

ANTHROPIC_API_KEY=

# ====================================
# REDIS
# ====================================

REDIS_URL=redis://localhost:6379/0

# ====================================
# APPLICATION
# ====================================

LOCAL_TEST=false